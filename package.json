{
  "name": "@rikology/adonisjs-xendit",
  "description": "AdonisJS v7 package for Xendit payment gateway integration",
  "version": "1.1.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "files": [
    "build",
    "!build/bin",
    "!build/tests",
    "!build/**/*.map",
    "LICENSE.md",
    "README.md",
    "CHANGELOG.md"
  ],
  "main": "build/index.js",
  "module": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./types": {
      "types": "./build/src/types.d.ts",
      "default": "./build/src/types.js"
    },
    "./xendit_provider": {
      "types": "./build/providers/xendit_provider.d.ts",
      "default": "./build/providers/xendit_provider.js"
    },
    "./errors": {
      "types": "./build/src/xendit_exception.d.ts",
      "default": "./build/src/xendit_exception.js"
    }
  },
  "scripts": {
    "copy:templates": "copyfiles \"stubs/**/*.stub\" build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "quick:test": "node --import=@poppinss/ts-exec --enable-source-maps bin/test.ts",
    "pretest": "npm run build",
    "test": "c8 npm run quick:test",
    "test:quick": "npm run quick:test",
    "precompile": "npm run lint",
    "compile": "tsdown && tsc --emitDeclarationOnly --declaration",
    "postcompile": "npm run copy:templates",
    "build": "npm run compile",
    "clean": "rm -rf build coverage",
    "release": "release-it",
    "release:preview": "release-it --dry-run",
    "version": "npm run build",
    "prepublishOnly": "npm run build && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rikoriswandha/adonisjs-xendit.git"
  },
  "homepage": "https://github.com/rikoriswandha/adonisjs-xendit#readme",
  "bugs": {
    "url": "https://github.com/rikoriswandha/adonisjs-xendit/issues"
  },
  "keywords": [
    "adonisjs",
    "adonis",
    "xendit",
    "payment",
    "payment-gateway",
    "fintech",
    "indonesia",
    "virtual-account",
    "ewallet",
    "qris",
    "invoice",
    "disbursement",
    "credit-card",
    "direct-debit",
    "payment-provider",
    "typescript"
  ],
  "author": "Riko Riswandha <rikoriswandha@gmail.com>",
  "license": "MIT",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/rikoriswandha"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/core": "^7.0.1",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/assert": "^4.2.0",
    "@japa/file-system": "^3.0.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/node": "^22.0.0",
    "c8": "^11.0.0",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/core": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@adonisjs/assembler": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": false,
    "registry": "https://registry.npmjs.org/"
  },
  "tsdown": {
    "entry": [
      "./index.ts",
      "./configure.ts",
      "./providers/xendit_provider.ts",
      "./src/types.ts",
      "./src/xendit_exception.ts"
    ],
    "outDir": "./build",
    "clean": true,
    "format": "esm",
    "minify": "dce-only",
    "fixedExtension": false,
    "dts": false,
    "treeshake": false,
    "sourcemaps": true,
    "target": "esnext"
  },
  "release-it": {
    "git": {
      "requireCleanWorkingDir": true,
      "requireUpstream": true,
      "commitMessage": "chore(release): ${version}",
      "tagAnnotation": "v${version}",
      "push": true,
      "tagName": "v${version}"
    },
    "github": {
      "release": true
    },
    "npm": {
      "publish": true,
      "skipChecks": false
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "c8": {
    "reporter": [
      "text",
      "html",
      "lcov"
    ],
    "exclude": [
      "tests/**",
      "bin/**",
      "build/**",
      "coverage/**",
      "stubs/**"
    ],
    "lines": 80,
    "functions": 80,
    "branches": 70,
    "statements": 80
  },
  "prettier": "@adonisjs/prettier-config"
}
